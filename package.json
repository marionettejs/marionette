{
  "name": "marionette",
  "description": "The Composite Javascript Framework",
  "version": "5.0.0-alpha.2",
  "homepage": "https://marionettejs.com/",
  "engines": {
    "node": ">=24"
  },
  "browser": "dist/marionette.umd.js",
  "main": "dist/marionette.cjs",
  "module": "dist/marionette.js",
  "exports": {
    ".": {
      "import": "./dist/marionette.js",
      "require": "./dist/marionette.cjs",
      "default": "./dist/marionette.js"
    },
    "./backbone": {
      "import": "./dist/backbone.js",
      "require": "./dist/backbone.cjs",
      "default": "./dist/backbone.js"
    },
    "./jquery-dom-api": {
      "types": "./dist/jquery-dom-api.d.ts",
      "import": "./dist/jquery-dom-api.js",
      "require": "./dist/jquery-dom-api.cjs",
      "default": "./dist/jquery-dom-api.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "readme.md",
    "license.txt",
    "changelog.md",
    "upgradeGuide.md"
  ],
  "sideEffects": [
    "./dist/backbone.js",
    "./dist/backbone.cjs"
  ],
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "keywords": [
    "backbone",
    "plugin",
    "marionette",
    "composite",
    "architecture",
    "single",
    "page",
    "app",
    "client",
    "browser"
  ],
  "license": "MIT",
  "scripts": {
    "build": "rollup -c --noConflict",
    "coverage": "vitest run --coverage",
    "coveralls": "npm run coverage && cat coverage/lcov.info | coveralls",
    "lint:base": "eslint backbone.js config/ index.js jquery-dom-api.js mixins/ modules/ test/fixtures/ test/setup/vitest.js test/unit/ utils/ vitest.config.js",
    "lint": "npm run lint:base -- --fix",
    "lint:ci": "npm run lint:base -- --max-warnings=0",
    "test": "vitest run",
    "test:fixtures": "node test/fixtures/run.mjs"
  },
  "bugs": {
    "url": "https://github.com/marionettejs/marionette/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marionettejs/marionette.git"
  },
  "github": "https://github.com/marionettejs/marionette",
  "peerDependencies": {
    "backbone": "^1.4.0",
    "jquery": "^3.5.0",
    "underscore": "^1.13.0"
  },
  "peerDependenciesMeta": {
    "backbone": {
      "optional": true
    },
    "jquery": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "7.29.6",
    "@babel/preset-env": "7.12.1",
    "@babel/register": "7.12.1",
    "@rollup/plugin-babel": "^5.2.1",
    "@rollup/plugin-commonjs": "^16.0.0",
    "@rollup/plugin-eslint": "^8.0.0",
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-multi-entry": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "backbone": "^1.4.0",
    "coveralls": "3.1.0",
    "easy-sauce": "0.4.2",
    "eslint": "7.13.0",
    "jquery": "3.5.1",
    "jsdom": "^24.1.3",
    "rollup": "2.33.1",
    "rollup-plugin-browsersync": "1.3.1",
    "rollup-plugin-node-globals": "1.4.0",
    "rollup-plugin-terser": "7.0.2",
    "sinon": "^19.0.0",
    "sinon-chai": "^4.0.0",
    "underscore": "^1.13.0",
    "vitest": "^4.1.8"
  }
}
